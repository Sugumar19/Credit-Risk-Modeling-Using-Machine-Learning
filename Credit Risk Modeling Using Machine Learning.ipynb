     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Lets check the dataframe model target\n",
    "df_model[target].value_counts() # 1 is good (lower risk) & 0 is bad (higher risk)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 86,
   "id": "38792982",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "['target_encoder.pkl']"
      ]
     },
     "execution_count": 86,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Using joblib dump to export the label encoder target\n",
    "joblib.dump(le_target, \"target_encoder.pkl\")\n",
    "# It saves the trained LabelEncoder for the target variable into a file named:target_encoder.pkl\n",
    "# It saves the target translator so we can use it later.\n",
    "# le_target: this the LabelEncoder which created before. At this time, it know the mapping of 0, 1, 2, ....\n",
    "# joblib.dump(labelencoder object, filename): # it takes an object (model or encoder), saves it as a file and stores it permanently in our c drive\n",
    "# So, when we deply the model, we can load this saved encoder like le_target = joblib.load(\"target_encoder.pkl\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "91feb5a8",
   "metadata": {},
   "source": [
    "### Workflow of ML Deployment\n",
    "1️⃣ Encode features\n",
    "\n",
    "2️⃣ Encode target\n",
    "\n",
    "3️⃣ Train model\n",
    "\n",
    "4️⃣ Save model (model.pkl)\n",
    "\n",
    "5️⃣ Save feature encoders\n",
    "\n",
    "6️⃣ Save target encoder\n",
    "\n",
    "7️⃣ Load everything in Streamlit\n",
    "\n",
    "8️⃣ Predict + decode result"
   ]
