   "id": "873ca4eb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Next step to encode the categorical columns\n",
    "from sklearn.preprocessing import LabelEncoder \n",
    "# sklearn = Scikit-learn: ML library used for Data preprocessing, model building & evaluation\n",
    "# LabelEncoder converts categorical text data into numbers. Because ML models cannot understand text.\n",
    "# data_frame = le.fit_transform(data_frame[categorical_columns])\n",
    "import joblib # Because we going to use it streamlit\n",
    "# joblib - save and load trained machine learning models.\n",
    "# Usually when the model created, it exists only in memory. If you close Python → it disappears.\n",
    "# To reuse that model again and again, you must save it (eg: joblib.dump(model, \"credit_model.pkl\")) in pkl file format.\n",
    "# Using this joblib, after trained the model we can save it and use it for later (SOS) in an app called streamlit."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "d8f0ab90",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Here we not going to perform any scaling operations, because here we are going to work with treebased models\n",
    "# You don't need scaling on these tree based models\n",
    "cat_cols = df_model.select_dtypes(include = \"object\").columns.drop(\"Risk\") # dropping target column"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 78,
   "id": "5d99945c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Lets create a dictionary for label encoder\n",
    "le_dict = {} # Will add the values inside of it later\n",
    "# Creating an empty dictionary for storing categorical coloumns and later we will incorporate labelencoder into it."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 79,
   "id": "25810392",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Index(['Sex', 'Housing', 'Saving accounts', 'Checking account'], dtype='object')"
      ]
     },
     "execution_count": 79,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Let check the categorical columns\n",
    "cat_cols"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 80,
   "id": "56c63869",
   "metadata": {},
   "outputs": [],
   "source": [
    "for col in cat_cols: # list of categorical columns & the loop runs once for each column\n",
    "    le = LabelEncoder() # here we are initializing the label encoder object:  this creates a LabelEncoder\n",
    "    # It like creating a translator for that specific column. Each column needs its own encoder.\n",
    "    df_model[col] = le.fit_transform(df_model[col]) # It converts text into numbers\n",
    "    le_dict[col] = le # here we are passing the categorical col values into the label encoder which we initialized two line above\n",
    "    # It stores the encoder in a dictionary\n",
    "    joblib.dump(le, f\"{col}_encoder.pkl\") # Saves the encoder as a file, later it can be deployed in Streamlit\n",
    "    \n",
    "# This is a very important preprocessing & deployment step: \n",
    "# Here we are encoding categorical columns, saving encoders, & preparing for Streamlit deployment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "092fc4a6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# We can check the working directory, in this above step: files with each \"categorical column name_encoder.pkl\" there"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 81,
   "id": "0f5a4c3b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Now lets label encode the target\n",
    "le_target = LabelEncoder() # This line creates a LabelEncoder object for the target column (for converting categorical to numeric)\n",
    "# It's like creating a translator for the output column\n",
    "# df_model[target]: This selects the target column."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 82,
   "id": "3bd8aac5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'Risk'"
      ]
     },
     "execution_count": 82,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Let's call the target\n",
    "target"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 83,
   "id": "b3180ecc",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_model[target] = le_target.fit_transform(df_model[target])\n",
    "# It converts the target column (\"Risk\") from text into numeric values.\n",
    "# le_target.fit_transform(...): It does two things:\n",
    "                                      # fit(): learns the unique values in the column and creates a mapping like 0, 1, for unique values\n",
    "                                      # transform(): It replaces the original values using that mapped values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 85,
   "id": "3a8b1d9d",
   "metadata": {},
   "outputs": [
