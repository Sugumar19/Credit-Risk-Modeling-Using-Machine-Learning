    "    plt.subplot(3, 3, i+1) # It divide the canvas into 9 small boxes - 3 rows & 3 columns\n",
    "    sns.countplot(data = df, x = col, palette = \"Set2\", order = df[col].value_counts().index)\n",
    "    # It creates a bar chart showing: How many times each category appears.\n",
